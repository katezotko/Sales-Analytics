      "source": [
        "def calculate_ab_test(data, metric_col, session_col='session'):\n",
        "    # Split data into Control and Treatment group\n",
        "    control = data[data['test_group'] == 1]\n",
        "    treatment = data[data['test_group'] == 2]\n",
        "\n",
        "    results = []\n",
        "\n",
        "    for test in data['test'].unique():\n",
        "        # Control and Treatment data for current test\n",
        "        c = control[control['test'] == test]\n",
        "        t = treatment[treatment['test'] == test]\n",
        "\n",
        "        # Skip if one of the groups is missing completely\n",
        "        if len(c) == 0 or len(t) == 0:\n",
        "            continue\n",
        "\n",
        "        # Number of sessions and successful events\n",
        "        control_sessions = c[session_col].sum()\n",
        "        treatment_sessions = t[session_col].sum()\n",
        "\n",
        "        control_success = c[metric_col].sum()\n",
        "        treatment_success = t[metric_col].sum()\n",
        "\n",
        "        if control_sessions == 0 or treatment_sessions == 0 or control_success == 0:\n",
        "            continue\n",
        "\n",
        "        cr_c = control_success / control_sessions\n",
        "        cr_t = treatment_success / treatment_sessions\n",
        "\n",
        "        if cr_c >= 1.0 or cr_t >= 1.0:\n",
        "            continue\n",
        "\n",
        "        # Perform Two-Proportion Z-Test\n",
        "        stat, pvalue = proportions_ztest(\n",
        "            count=[treatment_success, control_success],\n",
        "            nobs=[treatment_sessions, control_sessions]\n",
        "        )\n",
        "\n",
        "        # Relative change in conversion rate (% uplift)\n",
        "        uplift = ((cr_t - cr_c) / cr_c) * 100\n",
        "\n",
        "        results.append({\n",
        "            'test_number': test,\n",
        "            'metric': metric_col,\n",
        "            'numerator_ev': treatment_success,\n",
        "            'denominator_ev': treatment_sessions,\n",
        "            'conversion_rate_ev': cr_t,\n",
        "            'numerator_co': control_success,\n",
        "            'denominator_co': control_sessions,\n",
        "            'conversion_rate_co': cr_c,\n",
        "            'metric_change_%': uplift,\n",
        "            'z_stat': stat,\n",
        "            'p_value': pvalue,\n",
        "            'significant': pvalue < 0.05\n",
        "        })\n",
        "\n",
        "    return pd.DataFrame(results)\n"
      ],
